# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# SUPABASE_URL: The URL of your Supabase project (e.g. https://xyz.supabase.co)
SUPABASE_URL=https://placeholder-supabase-url.supabase.co

# SUPABASE_ANON_KEY: The public anonymous API key for your Supabase project
SUPABASE_ANON_KEY=placeholder-anon-key

# GOOGLE_WEB_CLIENT_ID: Required for Google OAuth.
GOOGLE_WEB_CLIENT_ID=276761045003-nvaq3tt78rph0sbq7asuviro67k2sv71.apps.googleusercontent.com
